# =========================================================================
# MISTER CHURRAS - CONFIGURAÇÃO DE AMBIENTE (CÓPIA LOCAL)
# =========================================================================
# Copie este arquivo para .env.local e insira as chaves reais.
# ATENÇÃO: NUNCA commite o arquivo .env.local com chaves de produção!

# 1. Supabase (Acesso ao Frontend e Auth)
VITE_SUPABASE_URL="sua_url_aqui"
VITE_SUPABASE_ANON_KEY="sua_anon_key_aqui"

# 2. Integração com Gemini (Tokens e IA do Mestre)
# IMPORTANTE: A API Key do Gemini NÃO deve ter o prefixo VITE_.
# Ela deve ser mantida apenas no backend (Supabase Edge Functions / Vercel Serverless)
# para evitar que usuários maliciosos extraiam seus tokens do bundle de produção!
GEMINI_API_KEY="seu_gemini_api_key_aqui"

# 3. Gateway de Mensagens (WhatsApp sovereign gateway)
# Usado localmente se necessário para o disparo offline de OTPs
GATEWAY_URL="http://localhost:3001"
GATEWAY_API_KEY="mister-churras-secret-2024"
