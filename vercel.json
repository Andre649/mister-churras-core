{
  "buildCommand": "npm install && cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@20.x"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|api$).*)",
      "destination": "/index.html"
    }
  ]
}
